# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/mineracao_db"

# Redis
REDIS_URL="redis://localhost:6379"

# urlscan.io (criar conta gratuita em urlscan.io)
URLSCAN_API_KEY="sua_chave_aqui"

# Workers
WORKER_CONCURRENCY=3
DISCOVERY_INTERVAL_HOURS=6
MAX_PAGINAS_POR_RUN=100

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
