# Convex
CONVEX_DEPLOYMENT=dev:your-deployment-slug
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud

# Redis (para BullMQ worker queues)
REDIS_URL="redis://localhost:6379"

# urlscan.io (criar conta gratuita em urlscan.io)
URLSCAN_API_KEY="sua_chave_aqui"

# Workers
WORKER_CONCURRENCY=3
DISCOVERY_INTERVAL_HOURS=6
MAX_PAGINAS_POR_RUN=100

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# HMR (used in next.config.ts, set to true to disable hot module replacement)
DISABLE_HMR=false
